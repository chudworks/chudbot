# grok-discord-bot configuration. Copy this file to `config.toml` and
# fill in the secrets. config.toml is gitignored.

# Floor-fallback persona. Must match a key under `[personas.*]` below.
# Top-level scalar — keep this BEFORE any `[section]` headers so the
# TOML parser doesn't attach it to whichever section was opened last.
default_persona = "default"

# Hard-coded operator admins, as Discord user ids. These users can pause
# the bot in a single conversation by reacting 🛑 (`:octagonal_sign:`) on
# any message the bot tracks for that conversation (the @mention, a bot
# reply, or any message inside a Grok-owned thread), and resume it by
# removing the reaction. The paused state shows in the web viewer. This
# is the operator's own kill-switch — distinct from Discord guild admins,
# who gate the `/grok-mode` and channel-scoped `/grok-persona` commands.
# Top-level scalar; keep it BEFORE any `[section]` header. Optional;
# omit (or leave empty) to disable the feature entirely. Ids are quoted
# STRINGS, not bare numbers — Discord snowflakes are gigantic 64-bit ids
# and quoting keeps them lossless.
# admins = ["123456789012345678", "234567890123456789"]

# Optional global system-prompt addendum, appended to EVERY persona's
# system prompt after the dynamically-built operational guidance (build
# version, model, enabled capabilities, conventions). Use it for
# deployment-wide rules that aren't part of any persona's voice — e.g.
# the Discord developer ToS or a content policy. Keep it BEFORE any
# `[section]` header (it's a top-level scalar). Optional; omit for none.
# extra_system_prompt = """
# This bot operates under the Discord Developer Terms of Service and
# Developer Policy. Do not produce content that violates them.
# """

[discord]
# Bot token from https://discord.com/developers/applications
token = "MTIzNDU2..."
# Optional: register slash commands to this guild only. Guild commands
# appear instantly; global commands take up to ~1 hour to propagate.
# Set to your server id during development; omit once the bot is going
# global. (Right-click your server icon → Copy Server ID, with Developer
# Mode enabled in Discord settings.)
# dev_guild_id = 123456789012345678

[postgres]
# Standard libpq connection URL. Local Postgres on the Mac Studio:
url = "postgres://chud@localhost/grok"

[web]
# Public base URL of the viewer; used to build the link the bot posts
# into Discord on new conversations.
base_url = "http://localhost:1860"
# host:port the Axum server binds. Defaults to 127.0.0.1:1860 — exposed
# only via loopback, matching the Cloudflare-tunnel deploy. Set to
# 0.0.0.0:<port> only if you want LAN/public exposure without a tunnel.
# listen = "127.0.0.1:1860"
# Directory the bot serves the built React frontend from. `serve.sh
# deploy` writes Vite's `dist/` here. Defaults to ./frontend-build.
# frontend_dir = "frontend-build"
# Prefix prepended to every browser-tab title in the viewer. The
# page-specific part (conversation title, "Viewer", "Not found", …) is
# appended after it. Defaults to "grok · ", e.g. "grok · My chat".
# title_prefix = "Chudbot · "
# Optional favicon served at /favicon.ico (browsers request it
# automatically). MUST live outside frontend_dir — `serve.sh deploy`
# replaces that whole directory, so a file inside it is wiped each
# deploy. A multi-resolution .ico is ideal; any browser-supported image
# works. Unset → browsers show their default icon.
# favicon_path = "/home/chud/chudbot/chudbot.ico"
# Whether the access logger trusts the X-Forwarded-For header for the
# client IP. Defaults to true, which is correct behind the Cloudflare
# tunnel (it sets the header). Set to false for a directly exposed
# deploy with no trusted proxy — otherwise clients can spoof their
# logged IP. When false (or the header is absent) the IP comes from the
# TCP peer address.
# trust_forwarded_for = true

# LLM provider credentials. Include only the blocks for providers any of
# your personas actually use. Several can be present — personas pick freely.
[llm.xai]
api_key = "xai-..."

# [llm.anthropic]
# api_key = "sk-ant-..."

# OpenAI (the real platform). Uses the Responses API — first-class tool
# calls, built-in web search, and encrypted-reasoning replay for prompt
# caching, on par with the xAI provider.
# [llm.openai]
# api_key = "sk-..."
# base_url = "https://api.openai.com/v1"   # optional; override for Azure etc.

# A self-hosted OpenAI-compatible host (vLLM / Ollama / LM Studio),
# spoken to over the Chat Completions API. `base_url` is REQUIRED (no
# default for a local host); `api_key` is optional (many local servers
# accept any/none). No server-side web search on this path; the model
# still drives the client-side tools. For tool calling, start vLLM with
# `--enable-auto-tool-choice --tool-call-parser <parser>`.
# [llm.openai_compat]
# base_url = "http://dgx.local:8000/v1"
# api_key = "anything"   # optional

# Image generation backend credentials. Symmetric with [llm.*]: include
# only the blocks for backends a persona's `image_provider` field names.
# A persona with no `image_provider` simply has no `generate_image` tool.
# xAI Grok Imagine and OpenAI (`gpt-image-1` family) are wired in; the
# `ImageProvider` trait in `core::imagegen` is the seam for adding more.
[image.xai]
api_key = "xai-..."  # typically the same key as [llm.xai]

# OpenAI images (`gpt-image-1` family) via /v1/images/{generations,edits}.
# [image.openai]
# api_key = "sk-..."
# base_url = "https://api.openai.com/v1"   # optional

# Video generation backend credentials. Same shape as `image`. (OpenAI's
# Sora video API is intentionally NOT wired in — it's deprecated, with a
# shutdown scheduled for 2026-09-24.)
[video.xai]
api_key = "xai-..."

# Bootstrap default for the per-guild privacy mode. Once a guild's
# admin runs `/grok-mode set`, the DB row takes over for that guild.
# Variants:
#   - { mode = "open", history_size = 20 }            # Design 1
#   - { mode = "channel_only", channel_id = 123, history_size = 20 }  # Design 2
#   - { mode = "opt_in" }                              # Design 3 (default)
#   - { mode = "conversation_only" }                   # Design 4
[default_privacy]
mode = "opt_in"

# Where to persist media. Files are saved as `<dir>/<uuid>.<ext>` and
# referenced in the DB by `file://images/<name>` or `file://videos/<name>`
# URIs (so future backends like s3:// can drop in without a schema
# change). Paths are relative to the bot's working directory; defaults
# are gitignored. `avatars_dir` holds cached Discord profile pictures
# keyed as `<user_id>_<hash>.<ext>` and is served at `/avatars/`.
[storage]
# images_dir = "images"
# videos_dir = "videos"
# avatars_dir = "avatars"

# Personas. Each one pairs a system prompt + sampling knobs with a
# specific (provider, model) pair. Users / channels / guilds /
# conversations can be pinned to a persona at runtime via the
# `/grok-persona set` slash command; resolution order is most-specific
# wins, falling back to `default_persona` at the top of this file when
# nothing matches.

[personas.default]
provider = "xai"
model = "grok-4.3"
system_prompt = """
You are a helpful AI assistant in a private Discord server. Be direct
and concise. Use web_search and x_search to ground claims; use
fetch_messages when you need surrounding conversation.
"""
# temperature = 0.7      # 0.0-2.0; higher = more chaotic, lower = focused
# top_p = 0.95           # 0.0-1.0; alternative sampling control
# Optional: name a backend for the `generate_image` / `generate_video`
# tools. The matching `[image.<kind>]` / `[video.<kind>]` block must be
# configured above; omitting these simply hides the corresponding tool
# from this persona.
image_provider = "xai"
video_provider = "xai"

# Example second persona — uncomment + add the [llm.anthropic] block
# above to enable.
# [personas.snark]
# provider = "anthropic"
# model = "claude-sonnet-4-6"
# system_prompt = """
# You are Chudbot, a sardonic and direct AI assistant. Don't hedge.
# """
# temperature = 1.0

# Example xAI persona using grok-4's reasoning effort. Only meaningful
# for reasoning-capable models (grok-4 family); other models silently
# ignore it. Valid values: "low" | "medium" | "high".
# [personas.researcher]
# provider = "xai"
# model = "grok-4.3"
# system_prompt = "You are a careful researcher. Cite your sources."
# image_provider = "xai"
# [personas.researcher.xai]
# reasoning_effort = "high"

# Example OpenAI persona (requires the [llm.openai] block above). Uses the
# Responses API. `reasoning_effort` is "minimal" | "low" | "medium" |
# "high" and only affects reasoning-capable models (gpt-5 family).
# [personas.gpt]
# provider = "openai"
# model = "gpt-5.5"
# system_prompt = "You are a helpful AI assistant."
# image_provider = "openai"
# [personas.gpt.openai]
# reasoning_effort = "medium"

# Example self-hosted persona (requires the [llm.openai_compat] block
# above). No web search; client-side tools (fetch_messages, image gen)
# still work if a host-served model supports tool calling.
# [personas.local]
# provider = "openai_compat"
# model = "qwen3"   # whatever model id your host serves
# system_prompt = "You are a helpful AI assistant."

