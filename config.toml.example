# grok-discord-bot configuration. Copy this file to `config.toml` and
# fill in the secrets. config.toml is gitignored.

# Floor-fallback persona. Must match a key under `[personas.*]` below.
# Top-level scalar — keep this BEFORE any `[section]` headers so the
# TOML parser doesn't attach it to whichever section was opened last.
default_persona = "default"

[discord]
# Bot token from https://discord.com/developers/applications
token = "MTIzNDU2..."
# Optional: register slash commands to this guild only. Guild commands
# appear instantly; global commands take up to ~1 hour to propagate.
# Set to your server id during development; omit once the bot is going
# global. (Right-click your server icon → Copy Server ID, with Developer
# Mode enabled in Discord settings.)
# dev_guild_id = 123456789012345678

[postgres]
# Standard libpq connection URL. Local Postgres on the Mac Studio:
url = "postgres://chud@localhost/grok"

[web]
# Public base URL of the viewer; used to build the link the bot posts
# into Discord on new conversations.
base_url = "http://localhost:8080"
# host:port the Axum server binds. Optional, defaults to 0.0.0.0:8080.
# listen = "127.0.0.1:8080"

# LLM provider credentials. Include only the blocks for providers any of
# your personas actually use. Both can be present — personas pick freely.
[llm.xai]
api_key = "xai-..."

# [llm.anthropic]
# api_key = "sk-ant-..."

# Image generation backend credentials. Symmetric with [llm.*]: include
# only the blocks for backends a persona's `image_provider` field names.
# A persona with no `image_provider` simply has no `generate_image` tool.
# Today xAI Grok Imagine is the only backend wired in; the `ImageProvider`
# trait in `core::imagegen` is the seam for adding more.
[image.xai]
api_key = "xai-..."  # typically the same key as [llm.xai]

# Video generation backend credentials. Same shape as `image`.
[video.xai]
api_key = "xai-..."

# Bootstrap default for the per-guild privacy mode. Once a guild's
# admin runs `/grok-mode set`, the DB row takes over for that guild.
# Variants:
#   - { mode = "open", history_size = 20 }            # Design 1
#   - { mode = "channel_only", channel_id = 123, history_size = 20 }  # Design 2
#   - { mode = "opt_in" }                              # Design 3 (default)
#   - { mode = "conversation_only" }                   # Design 4
[default_privacy]
mode = "opt_in"

# Where to persist media. Files are saved as `<dir>/<uuid>.<ext>` and
# referenced in the DB by `file://images/<name>` or `file://videos/<name>`
# URIs (so future backends like s3:// can drop in without a schema
# change). Paths are relative to the bot's working directory; both
# defaults are gitignored.
[storage]
# images_dir = "images"
# videos_dir = "videos"

# Personas. Each one pairs a system prompt + sampling knobs with a
# specific (provider, model) pair. Users / channels / guilds /
# conversations can be pinned to a persona at runtime via the
# `/grok-persona set` slash command; resolution order is most-specific
# wins, falling back to `default_persona` at the top of this file when
# nothing matches.

[personas.default]
provider = "xai"
model = "grok-4.3"
system_prompt = """
You are a helpful AI assistant in a private Discord server. Be direct
and concise. Use web_search and x_search to ground claims; use
fetch_messages when you need surrounding conversation.
"""
# temperature = 0.7      # 0.0-2.0; higher = more chaotic, lower = focused
# top_p = 0.95           # 0.0-1.0; alternative sampling control
# Optional: name a backend for the `generate_image` / `generate_video`
# tools. The matching `[image.<kind>]` / `[video.<kind>]` block must be
# configured above; omitting these simply hides the corresponding tool
# from this persona.
image_provider = "xai"
video_provider = "xai"

# Example second persona — uncomment + add the [llm.anthropic] block
# above to enable.
# [personas.snark]
# provider = "anthropic"
# model = "claude-sonnet-4-6"
# system_prompt = """
# You are Chudbot, a sardonic and direct AI assistant. Don't hedge.
# """
# temperature = 1.0

# Example xAI persona using grok-4's reasoning effort. Only meaningful
# for reasoning-capable models (grok-4 family); other models silently
# ignore it. Valid values: "low" | "medium" | "high".
# [personas.researcher]
# provider = "xai"
# model = "grok-4.3"
# system_prompt = "You are a careful researcher. Cite your sources."
# image_provider = "xai"
# [personas.researcher.xai]
# reasoning_effort = "high"

